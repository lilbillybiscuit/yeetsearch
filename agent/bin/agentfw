#!/usr/bin/env python3
import hashlib
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]


def usage():
    print(
        "usage: agentfw <init-state|validate-framework|hash-file|freeze-artifact|"
        "verify-artifact|inspect-project|render-prompts> ...",
        file=sys.stderr,
    )
    return 2


def sha256_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return "sha256:" + h.hexdigest()


def copytree_contents(src: Path, dst: Path) -> None:
    dst.mkdir(parents=True, exist_ok=True)
    for item in src.iterdir():
        target = dst / item.name
        if item.is_dir():
            shutil.copytree(item, target, dirs_exist_ok=True)
        else:
            shutil.copy2(item, target)


def init_state(argv):
    if len(argv) != 1:
        return usage()
    target = Path(argv[0])
    copytree_contents(ROOT / "templates" / "agent_state", target)
    print(str(target))
    return 0


def validate_framework(argv):
    if argv:
        return usage()
    required = [
        ROOT / "agents" / "common-contract.md",
        ROOT / "schemas" / "hypothesis.schema.json",
        ROOT / "schemas" / "spec.schema.json",
        ROOT / "templates" / "agent-manifest.yaml",
    ]
    missing = [str(p) for p in required if not p.exists()]
    if missing:
        print(json.dumps({"ok": False, "missing": missing}, indent=2))
        return 1
    schema_errors = []
    for path in sorted((ROOT / "schemas").glob("*.json")):
        try:
            json.loads(path.read_text())
        except Exception as exc:
            schema_errors.append({"path": str(path), "error": str(exc)})
    ok = not schema_errors
    print(json.dumps({"ok": ok, "schema_errors": schema_errors}, indent=2))
    return 0 if ok else 1


def hash_file(argv):
    if len(argv) != 1:
        return usage()
    print(sha256_file(Path(argv[0])))
    return 0


def freeze_artifact(argv):
    if len(argv) != 1:
        return usage()
    path = Path(argv[0])
    digest = sha256_file(path)
    sidecar = path.with_suffix(path.suffix + ".sha256")
    sidecar.write_text(digest + "\n")
    try:
        mode = path.stat().st_mode
        path.chmod(mode & ~0o222)
    except OSError:
        pass
    print(digest)
    return 0


def verify_artifact(argv):
    if len(argv) != 1:
        return usage()
    path = Path(argv[0])
    sidecar = path.with_suffix(path.suffix + ".sha256")
    if not sidecar.exists():
        print(json.dumps({"ok": False, "error": "missing sidecar"}))
        return 1
    expected = sidecar.read_text().strip()
    observed = sha256_file(path)
    ok = expected == observed
    print(json.dumps({"ok": ok, "expected": expected, "observed": observed}, indent=2))
    return 0 if ok else 1


def run_git(repo: Path, args):
    try:
        return subprocess.run(
            ["git"] + args,
            cwd=repo,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            timeout=10,
        )
    except Exception as exc:
        return exc


def inspect_project(argv):
    if len(argv) != 2:
        return usage()
    repo = Path(argv[0]).resolve()
    out = Path(argv[1])
    rev = run_git(repo, ["rev-parse", "HEAD"])
    if isinstance(rev, subprocess.CompletedProcess) and rev.returncode == 0:
        git_commit = rev.stdout.strip()
        git_error = None
    else:
        git_commit = None
        git_error = getattr(rev, "stderr", str(rev)).strip()
    files = []
    for path in sorted(repo.rglob("*")):
        rel = path.relative_to(repo)
        if any(part in {".git", "cmake-build-debug", "build"} for part in rel.parts):
            continue
        if path.is_file():
            files.append(str(rel))
        if len(files) >= 300:
            break
    instruction_files = []
    for name in ["AGENTS.md", "CLAUDE.md", "README.md"]:
        p = repo / name
        if p.exists():
            instruction_files.append(str(p.relative_to(repo)))
    docs = {}
    for name in [
        "docs/problem_spec.md",
        "docs/experiment_plan.md",
        "docs/research_log.md",
        "docs/implementation_notes.md",
    ]:
        p = repo / name
        docs[name] = p.exists()
    snapshot = {
        "project_path": str(repo),
        "git_commit": git_commit,
        "git_error": git_error,
        "instruction_files": instruction_files,
        "required_docs": docs,
        "file_sample": files,
    }
    out.parent.mkdir(parents=True, exist_ok=True)
    out.write_text(json.dumps(snapshot, indent=2) + "\n")
    print(str(out))
    return 0


NON_AGENT_FILES = {"common-contract"}
CODEX_MODEL = "gpt-5.5"
CODEX_SANDBOX_OVERRIDES = {
    "verifier": "read-only",
    "triage": "read-only",
}
CODEX_SANDBOX_DEFAULT = "workspace-write"


def _split_frontmatter(content: str):
    if not content.startswith("---\n"):
        return {}, content
    end = content.find("\n---\n", 4)
    if end == -1:
        return {}, content
    raw = content[4:end]
    body = content[end + 5 :]
    fm = {}
    for line in raw.splitlines():
        if ":" in line:
            key, _, value = line.partition(":")
            fm[key.strip()] = value.strip()
    return fm, body


def _extract_description(content: str, fallback: str) -> str:
    lines = content.splitlines()
    for idx, line in enumerate(lines):
        if line.strip() == "## Role":
            for role_line in lines[idx + 1 :]:
                if role_line.strip():
                    return role_line.strip()
            break
    for line in lines:
        stripped = line.strip()
        if stripped and not stripped.startswith("#"):
            return stripped
    return fallback


def _toml_string(value: str) -> str:
    escaped = value.replace("\\", "\\\\").replace('"', '\\"')
    return f'"{escaped}"'


def _toml_multiline(value: str) -> str:
    escaped = value.replace("\\", "\\\\")
    if '"""' in escaped:
        escaped = escaped.replace('"""', '\\"\\"\\"')
    return f'"""\n{escaped}\n"""'


def _render_claude_agent(name: str, content: str, agents_out: Path) -> None:
    fm, body = _split_frontmatter(content)
    description = fm.get("description") or _extract_description(content, f"{name} agent.")
    header_lines = [f"name: {name}", f"description: {description}"]
    for key in ("tools", "model"):
        if key in fm:
            header_lines.append(f"{key}: {fm[key]}")
    (agents_out / f"{name}.md").write_text(
        "---\n" + "\n".join(header_lines) + "\n---\n\n" + body.lstrip("\n")
    )


def _render_claude_skill(name: str, content: str, skills_out: Path) -> None:
    fm, body = _split_frontmatter(content)
    description = fm.get("description") or _extract_description(content, f"{name} skill.")
    skill_dir = skills_out / name
    skill_dir.mkdir(parents=True, exist_ok=True)
    (skill_dir / "SKILL.md").write_text(
        f"---\nname: {name}\ndescription: {description}\n---\n\n" + body.lstrip("\n")
    )


def _render_codex_agent(name: str, content: str, agents_out: Path) -> None:
    fm, _ = _split_frontmatter(content)
    description = fm.get("description") or _extract_description(content, f"{name} agent.")
    sandbox = CODEX_SANDBOX_OVERRIDES.get(name, CODEX_SANDBOX_DEFAULT)
    common_contract_path = ROOT / "agents" / "common-contract.md"
    pieces = []
    if common_contract_path.exists():
        pieces.append(common_contract_path.read_text().rstrip())
        pieces.append("")
    pieces.append(content.rstrip())
    instructions = "\n".join(pieces)
    toml = (
        f"name = {_toml_string(name)}\n"
        f"description = {_toml_string(description)}\n"
        f"model = {_toml_string(CODEX_MODEL)}\n"
        f"sandbox_mode = {_toml_string(sandbox)}\n\n"
        f"developer_instructions = {_toml_multiline(instructions)}\n"
    )
    (agents_out / f"{name}.toml").write_text(toml)


def render_prompts(argv):
    if len(argv) != 2 or argv[0] not in {"codex", "claude"}:
        return usage()
    target = argv[0]
    out = Path(argv[1])
    out.mkdir(parents=True, exist_ok=True)

    agents = [
        p for p in sorted((ROOT / "agents").glob("*.md")) if p.stem not in NON_AGENT_FILES
    ]
    skills = sorted((ROOT / "skills").glob("*.md"))

    if target == "claude":
        agents_out = out / ".claude" / "agents"
        agents_out.mkdir(parents=True, exist_ok=True)
        for path in agents:
            _render_claude_agent(path.stem, path.read_text(), agents_out)
        skills_out = out / ".claude" / "skills"
        skills_out.mkdir(parents=True, exist_ok=True)
        for path in skills:
            _render_claude_skill(path.stem, path.read_text(), skills_out)
    else:
        agents_out = out / ".codex" / "agents"
        agents_out.mkdir(parents=True, exist_ok=True)
        for path in agents:
            _render_codex_agent(path.stem, path.read_text(), agents_out)

    print(str(out))
    return 0


def main():
    if len(sys.argv) < 2:
        return usage()
    cmd, argv = sys.argv[1], sys.argv[2:]
    commands = {
        "init-state": init_state,
        "validate-framework": validate_framework,
        "hash-file": hash_file,
        "freeze-artifact": freeze_artifact,
        "verify-artifact": verify_artifact,
        "inspect-project": inspect_project,
        "render-prompts": render_prompts,
    }
    if cmd not in commands:
        return usage()
    return commands[cmd](argv)


if __name__ == "__main__":
    raise SystemExit(main())
